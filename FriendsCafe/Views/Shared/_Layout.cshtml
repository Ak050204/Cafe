<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link href="~/bootstrap/bootstrap.min.css" rel="stylesheet" />
    <style>
                        @@media screen and (max-width: 1800px) {
                           header {
            background-color:#5D1C34;
                           }
                           header img {
                               margin: 7px;
                               padding:5px;
                               width:80px;
                               height: 70px;
                           }
                           /*  .navbar-toggler {
                                border: 2px solid #A67D44 !important;
                           } */
                           header ul li a, .nav-link  {
                                    font-size:22px !important;
                                    color: #A67D44 !important;
                           }

                           .main {
                               background-color: #899481;
                           }

                           footer {
                               background-color: #cdbcab;
                               color:#11100f;
                           }
                        }
    </style>
</head>
<body>
    <header class="container-fluid">
        <div class=" row">
            <div class="col-sm-2">
                <img src="~/images/logo song with love.png" class="img-thumbnail" />
            </div>
            <div class="col-sm-2">
               <h3 class="font-monospace">The Daily Grand Cafe</h3>
            </div>
            
            <div class="col-sm-8">
                <nav class="navbar navbar-expand-sm navbar-dark">
                    <div class="container-fluid pt-1 mt-1.5">
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse" id="collapsibleNavbar">
                            <ul class="navbar-nav">
                                <li class="nav-item"><a class="nav-link" href="/home/home">Home</a></li>
                                <li class="nav-item"><a class="nav-link" href="/home/menu">Menu</a></li>
                                <li class="nav-item"><a class="nav-link" href="/home/aboutus">AboutUs</a></li>
                                <li class="nav-item"><a class="nav-link" href="/home/contactus">ContactUs</a></li>
                            </ul>
                        </div>
                    </div>
                </nav>
            </div>
        </div>

    </header>
    <div class="main container-fluid ">
        @RenderBody()
        <br>
    </div>

    <footer class="container-fluid mb-0">
        <div class="row">
            <div class="col-sm-4">
                <div class="footerpart">
                    <h3>About us</h3>
                    <p>The Friends Cafe is your ultimate neighborhood hangout spot. Enjoy freshly brewed coffee, delicious bites, and great conversations with friends. Come on in, grab a couch, and make yourself at home!</p>
                </div>
            </div>
            <div class="col-sm-4">
                <h3>Main Menu</h3>
                <ul>
                    <li>Coffee & Drinks</li>
                    <li>Breakfast & Brunch</li>
                    <li>Signature Burgers</li>
                    <li>Desserts & Shakes</li>
                    <li>Today's Specials</li>
                </ul>

                <ul>
                    <li><a href="/home/home">Home</a></li>
                    <li><a href="/home/menu">Menu</a></li>
                    <li><a href="/home/aboutus">About Us</a></li>
                    <li><a href="/home/contactus">Contact Us</a></li>
                </ul>
            </div>
            <div class="col-sm-4">
                <div class="footerpart">
                    <h3>Social Class</h3>
                    <p>ClassConnect with our community online for exclusive events, daily offers, and community highlights:</p>
                    <ul>
                        <li>Instagram</li>
                        <li>Facebook</li>
                    </ul>
                    <p>© 2026 The Friends Cafe. All Rights Reserved.</p>
                </div>
            </div>
        </div>

        

    </footer>
    <script src="~/bootstrap/bootstrap.bundle.min.js"></script>
</body>
</html>
